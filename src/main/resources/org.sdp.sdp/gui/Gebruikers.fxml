<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.sdp.sdp.gui.GebruikersController">
   <children>
      <StackPane style="-fx-background-color: white;" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <children>
            <VBox spacing="10.0">
               <children>
                  <TableView fx:id="tblGebruikers" prefHeight="200.0" prefWidth="200.0" VBox.vgrow="ALWAYS" />
                  <HBox spacing="10.0">
                     <children>
                        <TextField fx:id="txtNaam" promptText="Naam" />
                        <TextField fx:id="txtRol" promptText="Rol" />
                        <Button mnemonicParsing="false" onAction="#btnWijzigAction" text="Wijzigen" />
                        <Button mnemonicParsing="false" onAction="#btnVerwijderAction" text="Verwijderen" />
                        <Button mnemonicParsing="false" onAction="#btnToevoegenAction" text="Toevoegen" />
                     </children>
                     <padding>
                        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                     </padding>
                  </HBox>
               </children>
            </VBox>
         </children>
      </StackPane>
   </children>
</AnchorPane>
