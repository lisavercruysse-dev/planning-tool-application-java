<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<fx:root style="-fx-background-color: white;" type="javafx.scene.layout.VBox" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1">
    <children>
        <StackPane stylesheets="@../../styles/styles.css" VBox.vgrow="ALWAYS">
            <children>
                <VBox alignment="TOP_CENTER" spacing="10.0">
                    <children>
                        <TableView fx:id="teamsTbl" styleClass="table" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="naamCol" minWidth="100.0" prefWidth="150.0" text="naam" />
                                <TableColumn fx:id="verantwoordelijkeCol" minWidth="150.0" prefWidth="200.0" text="verantwoordelijke" />
                                <TableColumn fx:id="aantalLedenCol" minWidth="100.0" prefWidth="150.0" text="aantal leden" />
                                <TableColumn fx:id="siteCol" minWidth="100.0" prefWidth="100.0" text="site" />
                                <TableColumn fx:id="detailCol" minWidth="100.0" prefWidth="150.0" />
                            </columns>
                            <VBox.margin>
                                <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                            </VBox.margin>
                        </TableView>
                        <Button alignment="CENTER" mnemonicParsing="false" onAction="#toevoegenAction" styleClass="confirmButton" text="Toevoegen" />
                    </children>
                </VBox>
            </children>
        </StackPane>
    </children>
</fx:root>