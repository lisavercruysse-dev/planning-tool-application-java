<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<fx:root type="javafx.scene.layout.VBox" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1">
    <children>
        <StackPane style="-fx-background-color: white;" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <children>
                <VBox spacing="10.0">
                    <padding>
                        <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
                    </padding>
                    <children>
                        <!-- Tabel -->
                        <TableView fx:id="tblSites" styleClass="table" prefHeight="400.0" prefWidth="200.0" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="nameCol" text="Naam" />
                                <TableColumn fx:id="locatieCol" text="Locatie" />
                                <TableColumn fx:id="capaciteitCol" text="Capaciteit" />
                                <TableColumn fx:id="operationeleStatusCol" text="Operationele Status" />
                                <TableColumn fx:id="productieStatusCol" text="Productie Status" />
                            </columns>
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                        </TableView>

                        <HBox spacing="10.0">
                            <children>
                                <TextField fx:id="addName" promptText="Naam" />
                                <TextField fx:id="addLocatie" promptText="Locatie" />

                                <!--
                                <Button mnemonicParsing="false" onAction="#btnWijzigAction" text="Wijzigen" />
                                <Button mnemonicParsing="false" onAction="#btnVerwijderAction" text="Verwijderen" />

                                <Button mnemonicParsing="false" onAction="#btnToevoegenAction" text="Toevoegen" />
                                -->
                            </children>
                            <padding>
                                <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                            </padding>
                        </HBox>
                    </children>
                </VBox>
            </children>
        </StackPane>
    </children>
</fx:root>
